{
  "expo": {
    "name": "FluxRing Skia Starter",
    "slug": "fluxring",
    "version": "0.1.0",
    "scheme": "fluxring",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0E0C20",
    "newArchEnabled": true,
    "icon": "./icon.png",
    "splash": {
      "backgroundColor": "#0E0C20",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fluxring.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fluxring.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#0E0C20"
      }
    },
    "extra": {
      "eas": {
        "projectId": "d94a1082-9da2-459a-88b4-cd593c16eed3"
      },
      "googleAuth": {
        "webClientId": "",
        "iosClientId": "",
        "androidClientId": ""
      }
    }
  }
}
