rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Audio files and artwork are readable by authenticated users
    match /audio/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /artwork/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
